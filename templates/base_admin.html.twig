<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Admin Dashboard{% endblock %}</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    {{ encore_entry_link_tags('app') }}
    {{ encore_entry_link_tags('admin') }}

    {% block stylesheets %}{% endblock %}
</head>

<body class = "admin-mode">

<div class="d-flex">

    <div class="sidebar">

        <div class="text-center text-white py-4 border-bottom">
            <h4>Hobbini Admin</h4>
        </div>

        <a href="{{ path('admin_dashboard') }}">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <a href="{{ path('admin_product_stock') }}">
            <i class="bi bi-box-seam"></i> Produits
        </a>

        <a href="{{ path('admin_order_index') }}">
            <i class="bi bi-cart-check"></i> Commandes
        </a>

        <a href="{{ path('product_index') }}">
            <i class="bi bi-shop"></i> Boutique
        </a>

        <a href="{{ path('app_logout') }}">
            <i class="bi bi-box-arrow-right"></i> Déconnexion
        </a>

    </div>

    <div class="admin-content w-100">

        <nav class="admin-navbar navbar navbar-dark rounded px-4 mb-4">

            <span class="navbar-brand mb-0 h5">
                Dashboard Administrateur
            </span>

            <span class="text-white">
                👤 {{ app.user.userIdentifier|split('@')[0] }}
            </span>

        </nav>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}

    </div>

</div>

{{ encore_entry_script_tags('app') }}
{{ encore_entry_link_tags('admin') }}

</body>
</html>

