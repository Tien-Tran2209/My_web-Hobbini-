<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Hobbini{% endblock %}</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    {{ encore_entry_link_tags('app') }}
    {{ encore_entry_link_tags('admin') }}

    {% block stylesheets %}{% endblock %}
</head>

<body class="
    d-flex flex-column min-vh-100
    {% if is_granted('ROLE_ADMIN') %}admin-mode{% endif %}
">

<nav class="navbar navbar-expand-lg navbar-dark px-4">

    <a class="navbar-brand d-flex align-items-center" href="{{ path('product_index') }}">
        <img src="{{ asset('images/Logo-hobbini.png') }}" alt="Logo" height="40" class="me-2">
        <span class="fw-bold text-white">Hobbini</span>
    </a>

    <div class="mx-auto text-white fw-semibold">
        Bienvenue à Hobbini
    </div>

    <div class="d-flex align-items-center">

        {% if app.user %}

            {% if is_granted('ROLE_ADMIN') %}
                <span class="text-white me-3 d-flex align-items-center">
                    👤 Admin
                </span>
            {% else %}
                <div class="position-relative me-3">

                    <a href="{{ path('user_profile') }}"
                    class="text-white text-decoration-none">

                        <i class="bi bi-cart3 fs-4"></i>

                        {% if cart_count() > 0 %}
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                {{ cart_count() }}
                            </span>
                        {% endif %}
                    </a>

                </div>
            {% endif %}

            <a href="{{ path('app_logout') }}" class="btn btn-outline-light btn-sm">
                Déconnexion
            </a>

        {% else %}
            <a href="{{ path('app_login') }}" class="btn btn-outline-light btn-sm">
                Connecter
            </a>
        {% endif %}

    </div>

</nav>

<main class="container mt-4 content flex-grow-1">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}
    
    {% block body %}{% endblock %}
</main>

<footer class="text-white text-center p-3 mt-auto">
    <small>© {{ "now"|date("Y") }} Hobbini. Every Step Counts - Every Moment Matters.</small>
</footer>

{{ encore_entry_script_tags('app') }}
{{ encore_entry_link_tags('admin') }}
</body>
</html>