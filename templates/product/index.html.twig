{% extends 'base.html.twig' %}

{% block title %}Liste des Produits{% endblock %}

{% block body %}

<div class="page-wrapper">

    <div class="page-header">

        <div class="header-left">
            <h1 class="page-title">📦 Liste des Produits</h1>
        </div>

        <form method="get"
              action="{{ path('product_index') }}"
              class="filter-box">

            <span class="filter-label">🔎 Filtrer :</span>

            <select name="category" onchange="this.form.submit()">
                <option value="">Tous les produits</option>

                {% for cat in categories %}
                    <option value="{{ cat.id }}"
                            {% if cat.id == selectedCategory %}selected{% endif %}>
                        {{ cat.name }}
                    </option>
                {% endfor %}
            </select>

        </form>

    </div>

{% if is_granted('ROLE_ADMIN') %}
    <a href="{{ path('admin_product_new') }}" class="btn-custom">➕ Ajouter Produit</a>
    <a href="{{ path('admin_order_index') }}" class="btn-custom">📦 Commandes</a>
    <a href="{{ path('admin_product_stock') }}" class="btn-custom">📊 Stock</a>
    <a href="{{ path('admin_dashboard') }}" class="btn-custom">📈 Dashboard</a>
{% endif %}

<div class="product-grid">

    {% for product in products %}

        <div class="product-card">

            <div class="product-image">
                <img src="{{ asset(product.imageUrl) }}" alt="{{ product.name }}">
            </div>

            <div class="product-body">

                <div class="product-name">{{ product.name }}</div>

                <div class="product-price">{{ product.price }} €</div>

                <div class="product-meta">

                    {% if is_granted('ROLE_ADMIN') %}
                        <span>Vendu: {{ product.sold }}</span>
                    {% else %}
                        <span>Disponible: {{ product.remaining }}</span>
                    {% endif %}

                    <span>
                        {% if product.remaining == 0 %}
                            <span class="badge badge-danger">Rupture</span>
                        {% elseif product.sold > 20 %}
                            <span class="badge badge-hot">🔥 Hot</span>
                        {% else %}
                            <span class="badge badge-success">Stock</span>
                        {% endif %}
                    </span>

                </div>

                <a href="{{ path('product_show', {id: product.id}) }}" class="btn-view">
                    Voir détails →
                </a>

            </div>

        </div>

    {% else %}
        <p class="empty-text">Aucun produit pour le moment.</p>
    {% endfor %}

</div>

<div class="d-flex justify-content-center mt-4">
    {{ knp_pagination_render(products, '@KnpPaginator/Pagination/bootstrap_v5_pagination.html.twig') }}
</div>

{% endblock %}