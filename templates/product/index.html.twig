{% extends 'base.html.twig' %}

{% block title %}Liste des Produits{% endblock %}

{% block body %}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        padding: 15px 20px;
        background: rgba(255,255,255,0.85);
        border-radius: 16px;
        box-shadow: 0 6px 15px rgba(0,0,0,0.08);
        backdrop-filter: blur(6px);
    }

    .page-title {
        font-weight: 800;
        color: #7B8CD8;
        margin: 0;
        font-size: 26px;
    }

    .btn-custom {
        background: #7B8CD8;
        color: white;
        border-radius: 10px;
        padding: 10px 14px;
        text-decoration: none;
        display: inline-block;
        margin-right: 10px;
        margin-bottom: 15px;
        transition: 0.2s;
        font-weight: 600;
    }

    .btn-custom:hover {
        background: #6678cf;
        color: white;
    }

    .filter-box {
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .filter-box select {
        padding: 8px 10px;
        border-radius: 10px;
        border: 1px solid rgba(0,0,0,0.15);
        outline: none;
        cursor: pointer;
        background: white;
    }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 20px;
        margin-top: 25px;
    }

    .product-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 6px 18px rgba(0,0,0,0.10);
        transition: 0.25s ease;
        display: flex;
        flex-direction: column;
    }

    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 28px rgba(0,0,0,0.18);
    }

    .product-image {
        width: 100%;
        height: 180px;
        overflow: hidden;
    }

    .product-image img {
        width: 100%;
        height: 200px;
        object-fit: contain;
        background: #f5f5f5;
    }

    .product-card:hover .product-image img {
        transform: scale(1.05);
    }

    .product-body {
        padding: 12px 14px;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .product-name {
        font-weight: 700;
        font-size: 15px;
        color: #333;
        min-height: 40px;
    }

    .product-price {
        font-weight: 700;
        color: #7B8CD8;
        font-size: 16px;
    }

    .product-actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 10px;
    }

    .btn-view {
        background: #7B8CD8;
        color: white;
        padding: 7px 12px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        transition: 0.2s;
    }

    .btn-view:hover {
        background: #5f6fd1;
    }

    .empty-text {
        text-align: center;
        color: rgba(0,0,0,0.5);
        margin-top: 20px;
    }
</style>

<div class="page-header">

    <h1 class="page-title">📦 Liste des Produits</h1>

    <form method="get" action="{{ path('product_index') }}" class="filter-box">
        <label for="category">Filtrer :</label>
        <select name="category" id="category" onchange="this.form.submit()">
            <option value="">Tous</option>
            {% for cat in categories %}
                <option value="{{ cat.id }}" {% if cat.id == selectedCategory %}selected{% endif %}>
                    {{ cat.name }}
                </option>
            {% endfor %}
        </select>
    </form>

</div>

{# ADMIN BUTTONS #}
{% if is_granted('ROLE_ADMIN') %}
    <a href="{{ path('admin_product_new') }}" class="btn-custom">➕ Ajouter Produit</a>
    <a href="{{ path('admin_order_index') }}" class="btn-custom">📦 Commandes</a>
    <a href="{{ path('admin_product_stock') }}" class="btn-custom">📊 Stock</a>
{% endif %}

{# PRODUCTS #}
<div class="product-grid">

    {% for product in products %}
        <div class="product-card">

            <div class="product-image">
                <img src="{{ asset(product.imageUrl) }}" alt="{{ product.name }}">
            </div>

            <div class="product-body">

                <div class="product-name">
                    {{ product.name }}
                </div>

                <div class="product-price">
                    {{ product.price }} €
                </div>

                <div class="product-actions">
                    <a href="{{ path('product_show', {id: product.id}) }}" class="btn-view">
                        Voir détails
                    </a>
                </div>

            </div>

        </div>
    {% else %}
        <p class="empty-text">Aucun produit pour le moment.</p>
    {% endfor %}

</div>

<div class="d-flex justify-content-center mt-4">
    {{ knp_pagination_render(products, '@KnpPaginator/Pagination/bootstrap_v5_pagination.html.twig') }}
</div>

{% endblock %}