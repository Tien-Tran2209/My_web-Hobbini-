{% extends 'base_admin.html.twig' %}

{% block title %}Ajouter un produit{% endblock %}

{% block body %}

<div class="form-container">

    <h1 class="form-title">
        Ajouter un produit
    </h1>

    {{ form_start(form) }}

    <div class="form-grid">

        <div class="form-group">
            {{ form_label(form.name, "Nom") }}
            {{ form_widget(form.name) }}
        </div>

        <div class="form-group">
            {{ form_label(form.price, "Prix") }}
            {{ form_widget(form.price) }}
        </div>

        <div class="form-group">
            {{ form_label(form.stock, "Stock") }}
            {{ form_widget(form.stock) }}
        </div>

        <div class="form-group">
            {{ form_label(form.category, "Catégorie") }}
            {{ form_widget(form.category) }}
        </div>

        <div class="form-group full">
            {{ form_label(form.image_url, "URL de l'image") }}
            {{ form_widget(form.image_url) }}
        </div>

        <div class="form-group full">
            {{ form_label(form.description, "Description") }}
            {{ form_widget(form.description) }}
        </div>

    </div>

    <button type="submit" class="btn-submit">
        <i class="bi bi-plus-circle"></i>
        Ajouter produit
    </button>

    {{ form_end(form) }}

</div>

{% endblock %}