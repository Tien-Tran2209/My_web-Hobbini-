{% extends 'base.html.twig' %}

{% block title %}Ajouter un produit{% endblock %}

{% block body %}

<style>
    .form-container {
        max-width: 750px;
        margin: 30px auto;
        background: white;
        padding: 25px;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.10);
    }

    .form-title {
        font-size: 26px;
        font-weight: 800;
        color: var(--primary, #7B8CD8);
        margin-bottom: 20px;
        text-align: center;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    label {
        font-weight: 600;
        font-size: 14px;
        color: #444;
    }

    input,
    select,
    textarea {
        padding: 10px;
        border-radius: 10px;
        border: 1px solid rgba(0,0,0,0.15);
        outline: none;
        transition: 0.2s;
        font-size: 14px;
    }

    input:focus,
    select:focus,
    textarea:focus {
        border-color: var(--primary, #7B8CD8);
        box-shadow: 0 0 0 2px rgba(123,140,216,0.15);
    }

    .full {
        grid-column: span 2;
    }

    /* BUTTON */
    .btn-submit {
        width: 100%;
        margin-top: 20px;
        padding: 12px;
        background: var(--primary, #7B8CD8);
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: 700;
        cursor: pointer;
        transition: 0.2s;
    }

    .btn-submit:hover {
        background: var(--primary-dark, #5f6fd1);
    }

    /* MOBILE */
    @media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }

        .full {
            grid-column: span 1;
        }
    }
</style>

<div class="form-container">

    <h1 class="form-title">
        Ajouter un produit
    </h1>

    {{ form_start(form) }}

    <div class="form-grid">

        <div class="form-group">
            {{ form_label(form.name) }}
            {{ form_widget(form.name) }}
        </div>

        <div class="form-group">
            {{ form_label(form.price) }}
            {{ form_widget(form.price) }}
        </div>

        <div class="form-group">
            {{ form_label(form.stock) }}
            {{ form_widget(form.stock) }}
        </div>

        <div class="form-group">
            {{ form_label(form.category) }}
            {{ form_widget(form.category) }}
        </div>

        <div class="form-group full">
            {{ form_label(form.image_url) }}
            {{ form_widget(form.image_url) }}
        </div>

        <div class="form-group full">
            {{ form_label(form.description) }}
            {{ form_widget(form.description) }}
        </div>

    </div>

    <button type="submit" class="btn-submit">
        <i class="bi bi-plus-circle"></i>
        Ajouter produit
    </button>

    {{ form_end(form) }}

</div>

{% endblock %}