{% extends 'base.html.twig' %}

{% block title %}Modifier Produit{% endblock %}

{% block body %}

<style>
    .form-container {
        max-width: 800px;
        margin: 30px auto;
        background: white;
        padding: 25px;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .form-title {
        font-size: 26px;
        font-weight: 800;
        color: var(--logo-text-color, #7B8CD8);
        margin-bottom: 20px;
        text-align: center;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    label {
        font-weight: 600;
        font-size: 14px;
        color: #444;
        margin-bottom: 5px;
    }

    input,
    select,
    textarea {
        width: 100%;
        padding: 10px;
        border-radius: 10px;
        border: 1px solid rgba(0,0,0,0.15);
        font-size: 14px;
        outline: none;
        transition: 0.2s;
    }

    input:focus,
    select:focus,
    textarea:focus {
        border-color: #7B8CD8;
        box-shadow: 0 0 0 2px rgba(123,140,216,0.15);
    }

    .full {
        grid-column: span 2;
    }

    /* BUTTON SYSTEM (consistent) */
    .btn-primary {
        width: 100%;
        margin-top: 20px;
        padding: 12px;
        background: #7B8CD8;
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: 700;
        font-size: 16px;
        cursor: pointer;
        transition: 0.2s;
    }

    .btn-primary:hover {
        background: #5f6fd1;
    }

    /* MOBILE */
    @media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }

        .full {
            grid-column: span 1;
        }
    }
</style>

<div class="form-container">

    <h1 class="form-title">
        ✏️ Modifier Produit
    </h1>

    {{ form_start(form) }}

    <div class="form-grid">

        <div>
            {{ form_label(form.name) }}
            {{ form_widget(form.name) }}
        </div>

        <div>
            {{ form_label(form.price) }}
            {{ form_widget(form.price) }}
        </div>

        <div>
            {{ form_label(form.image_url) }}
            {{ form_widget(form.image_url) }}
        </div>

        <div>
            {{ form_label(form.category) }}
            {{ form_widget(form.category) }}
        </div>

        <div>
            {{ form_label(form.stock) }}
            {{ form_widget(form.stock) }}
        </div>

        <div class="full">
            {{ form_label(form.description) }}
            {{ form_widget(form.description, {'attr': {'rows': 4}}) }}
        </div>

    </div>

    <button type="submit" class="btn-primary">
        <i class="bi bi-check2-circle me-1"></i>
        Sauvegarder
    </button>

    {{ form_end(form) }}

</div>

{% endblock %}