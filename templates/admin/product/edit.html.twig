{% extends 'base_admin.html.twig' %}

{% block title %}Modifier Produit{% endblock %}

{% block body %}

<div class="form-container">

    <h1 class="form-title">
        ✏️ Modifier Produit
    </h1>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="flash-msg {% if label == 'success' %}flash-success{% else %}flash-error{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}
    
    {{ form_start(form) }}

    <div class="form-grid">

        <div class="form-group">
            {{ form_label(form.name, "Nom") }}
            {{ form_widget(form.name) }}
        </div>

        <div class="form-group">
            {{ form_label(form.price, "Prix") }}
            {{ form_widget(form.price) }}
            {% for error in form.price.vars.errors %}
                <div class="text-danger small mt-1">
                    {{ error.message }}
                </div>
            {% endfor %}
        </div>

        <div class="form-group">
            {{ form_label(form.image_url, "URL de l'image") }}
            {{ form_widget(form.image_url) }}
        </div>

        <div class="form-group">
            {{ form_label(form.category, "Catégorie") }}
            {{ form_widget(form.category) }}
        </div>

        <div class="form-group">
            {{ form_label(form.stock, "Stock") }}
            {{ form_widget(form.stock) }}
        </div>

        <div class="form-group full">
            {{ form_label(form.description, "Description") }}
            {{ form_widget(form.description, {'attr': {'rows': 4}}) }}
        </div>

    </div>

    <button type="submit" class="btn-submit">
        <i class="bi bi-check2-circle me-1"></i>
        Sauvegarder
    </button>

    {{ form_end(form) }}

</div>

{% endblock %}