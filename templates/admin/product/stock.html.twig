{% extends 'base.html.twig' %}

{% block title %}Gestion Produits{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/product-stock.css') }}">
{% endblock %}

{% block body %}

<h1 class="page-title">
    📦 Gestion Produits
</h1>

<div class="table-container">

    <table>

        <tr>
            <th>Image</th>
            <th>Produit</th>
            <th>Prix</th>
            <th>Stock</th>
            <th>Déjà vendu</th>
            <th>Restant</th>
        </tr>

        {% for row in stats %}
            <tr>

                <td>
                    <img src="{{ asset(row.product.imageUrl) }}" width="70">
                </td>

                <td>{{ row.product.name }}</td>

                <td><strong>{{ row.product.price }} €</strong></td>

                <td>

                    <form method="post"
                          action="{{ path('admin_product_stock_update', {id: row.product.id}) }}"
                          class="stock-form">

                        <input type="number"
                               name="stock"
                               value="{{ row.product.stock }}"
                               min="0">

                        <button type="submit" class="btn-save">
                            <i class="bi bi-check-lg"></i>
                        </button>

                    </form>

                </td>

                <td>{{ row.sold }}</td>

                <td>

                    {% if row.remaining > 0 %}
                        <span class="badge badge-success">
                            {{ row.remaining }}
                        </span>
                    {% else %}
                        <span class="badge badge-danger">
                            Rupture
                        </span>
                    {% endif %}

                </td>

            </tr>
        {% endfor %}

    </table>

</div>

<div class="d-flex justify-content-center mt-4">
    {{ knp_pagination_render(pagination, '@KnpPaginator/Pagination/bootstrap_v5_pagination.html.twig') }}
</div>

{% endblock %}