{% extends 'base.html.twig' %}

{% block title %}Gestion Produits{% endblock %}

{% block body %}

<style>
    .page-title {
        font-size: 26px;
        font-weight: 800;
        color: var(--primary, #7B8CD8);
        margin-bottom: 20px;
        text-align: center;
    }

    .table-container {
        max-width: 1100px;
        margin: 20px auto;
        background: white;
        padding: 20px;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        text-align: center;
        padding: 12px;
        font-size: 13px;
        color: #666;
        border-bottom: 2px solid #eee;
    }

    td {
        text-align: center;
        padding: 12px;
        font-size: 14px;
        border-bottom: 1px solid #f1f1f1;
        vertical-align: middle;
    }

    tr:hover {
        background: #fafafa;
    }

    img {
        border-radius: 8px;
    }

    /* STOCK FORM */
    .stock-form {
        display: flex;
        justify-content: center;
        gap: 6px;
        align-items: center;
    }

    .stock-form input {
        width: 80px;
        padding: 6px;
        border-radius: 8px;
        border: 1px solid #ddd;
        text-align: center;
        outline: none;
    }

    .stock-form input:focus {
        border-color: var(--primary, #7B8CD8);
        box-shadow: 0 0 0 2px rgba(123,140,216,0.15);
    }

    .btn-save {
        background: var(--primary, #7B8CD8);
        color: white;
        border: none;
        padding: 6px 10px;
        border-radius: 8px;
        cursor: pointer;
        transition: 0.2s;
    }

    .btn-save:hover {
        background: var(--primary-dark, #5f6fd1);
    }

    /* BADGES */
    .badge {
        display: inline-block;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }

    .badge-danger {
        background: #e74c3c;
        color: white;
    }

    .badge-success {
        background: #2ecc71;
        color: white;
    }
</style>

<h1 class="page-title">
    📦 Gestion Produits
</h1>

<div class="table-container">

    <table>

        <tr>
            <th>Image</th>
            <th>Produit</th>
            <th>Prix</th>
            <th>Stock</th>
            <th>Déjà vendu</th>
            <th>Restant</th>
        </tr>

        {% for row in stats %}
            <tr>

                <td>
                    <img src="{{ asset(row.product.imageUrl) }}" width="70">
                </td>

                <td>{{ row.product.name }}</td>

                <td><strong>{{ row.product.price }} €</strong></td>

                <td>

                    <form method="post"
                          action="{{ path('admin_product_stock_update', {id: row.product.id}) }}"
                          class="stock-form">

                        <input type="number"
                               name="stock"
                               value="{{ row.product.stock }}"
                               min="0">

                        <button type="submit" class="btn-save">
                            <i class="bi bi-check-lg"></i>
                        </button>

                    </form>

                </td>

                <td>{{ row.sold }}</td>

                <td>

                    {% if row.remaining > 0 %}
                        <span class="badge badge-success">
                            {{ row.remaining }}
                        </span>
                    {% else %}
                        <span class="badge badge-danger">
                            Rupture
                        </span>
                    {% endif %}

                </td>

            </tr>
        {% endfor %}

    </table>

</div>

{% endblock %}