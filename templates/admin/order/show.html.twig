{% extends 'base.html.twig' %}

{% block title %}Commande #{{ order.id }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/order-show.css') }}">
{% endblock %}

{% block body %}

<div class="order-container">

    <h1 class="page-title">
        🧾 Commande #{{ order.id }}
    </h1>

    <div class="card order-info">

        <p><strong>User:</strong> {{ order.user.email }}</p>
        <p><strong>Date:</strong> {{ order.createdAt|date('d/m/Y H:i') }}</p>

        <p>
            <strong>Status:</strong>
            <span class="status
                {% if order.status == 'En attente' %}status-attente{% endif %}
                {% if order.status == 'Validé' %}status-valide{% endif %}
                {% if order.status == 'Expédié' %}status-expedie{% endif %}
                {% if order.status == 'Annulé' %}status-annule{% endif %}
            ">
                {{ order.status }}
            </span>
        </p>

        <p>
            <strong>Payment method:</strong>
            {% if order.paymentMethod == 'stripe' %}
                💳 Carte bancaire
            {% else %}
                💵 Paiement à la livraison
            {% endif %}
        </p>

        <p>
            <strong>Payment status:</strong>

            {% if order.paymentStatus == 'paid' %}
                <span class="pay-paid">✅ Payé</span>
            {% elseif order.paymentStatus == 'pending' %}
                <span class="pay-pending">⏳ En attente</span>
            {% else %}
                <span class="pay-failed">❌ Échoué</span>
            {% endif %}
        </p>

    </div>

    <a href="{{ path('admin_order_index') }}" class="btn-back">
        ← Retour commandes
    </a>

    <div class="card">

        <h3 style="margin-bottom:15px; color:#7B8CD8;">
            📦 Produits
        </h3>

        <table>
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Produit</th>
                    <th>Quantité</th>
                    <th>Prix</th>
                    <th>Total</th>
                </tr>
            </thead>

            <tbody>
                {% for item in order.orderItems %}
                    <tr>
                        <td>
                            <img src="{{ asset(item.product.imageUrl) }}" width="60">
                        </td>
                        <td>{{ item.product.name }}</td>
                        <td>{{ item.quantity }}</td>
                        <td>{{ item.product.price }} €</td>
                        <td><strong>{{ item.quantity * item.product.price }} €</strong></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        <div class="total-box">
            Total: {{ order.totalPrice }} €  
        </div>

    </div>

</div>

{% endblock %}