{% extends 'base.html.twig' %}

{% block title %}Commande #{{ order.id }}{% endblock %}

{% block body %}

<style>
    .page-title {
        text-align: center;
        font-size: 26px;
        font-weight: 800;
        color: var(--primary, #7B8CD8);
        margin-bottom: 30px;
    }

    .order-container {
        max-width: 1000px;
        margin: 30px auto;
    }

    .card {
        background: white;
        padding: 20px;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        margin-bottom: 20px;
    }

    .order-info p {
        margin: 6px 0;
        font-size: 14px;
        color: #444;
    }

    /* STATUS */
    .status {
        display: inline-block;
        padding: 5px 10px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 13px;
    }

    .status-attente { background: #f39c12; color: white; }
    .status-valide { background: #7B8CD8; color: white; }
    .status-expedie { background: #2ecc71; color: white; }
    .status-annule { background: #e74c3c; color: white; }

    /* TABLE */
    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        text-align: left;
        padding: 10px;
        font-size: 13px;
        color: #666;
        border-bottom: 2px solid #eee;
    }

    td {
        padding: 12px;
        font-size: 14px;
        border-bottom: 1px solid #f1f1f1;
        vertical-align: middle;
    }

    tr:hover {
        background: #fafafa;
    }

    img {
        border-radius: 8px;
    }

    /* TOTAL */
    .total-box {
        text-align: right;
        font-size: 18px;
        font-weight: 800;
        color: var(--primary, #7B8CD8);
        margin-top: 10px;
    }

    /* BACK (IMPROVED VISUAL ONLY, SAME POSITION) */
    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 15px; /* giữ vị trí nhưng tạo khoảng thở */
        background: #ffffff;
        padding: 10px 14px;
        border-radius: 12px;
        color: #7B8CD8;
        text-decoration: none;
        font-weight: 700;
        border: 1px solid rgba(123,140,216,0.2);
        transition: 0.2s;
    }

    .btn-back i {
        font-size: 14px;
        color: #7B8CD8;
    }

    .btn-back:hover {
        background: #f5f7ff;
        transform: translateX(-3px);
    }
</style>

<div class="order-container">

    <!-- TITLE -->
    <h1 class="page-title">
        🧾 Commande #{{ order.id }}
    </h1>

    <!-- ORDER INFO -->
    <div class="card order-info">
        <p><strong>User:</strong> {{ order.user.email }}</p>
        <p><strong>Date:</strong> {{ order.createdAt|date('d/m/Y H:i') }}</p>

        <p>
            <strong>Status:</strong>
            <span class="status
                {% if order.status == 'En attente' %}status-attente{% endif %}
                {% if order.status == 'Validé' %}status-valide{% endif %}
                {% if order.status == 'Expédié' %}status-expedie{% endif %}
                {% if order.status == 'Annulé' %}status-annule{% endif %}
            ">
                {{ order.status }}
            </span>
        </p>
    </div>

    <a href="{{ path('admin_order_index') }}" class="btn-back">
        <i class="bi bi-arrow-left"></i>
        Retour commandes
    </a>

    <!-- PRODUCTS -->
    <div class="card">

        <h3 style="margin-bottom:15px; color:#7B8CD8;">
            📦 Produits
        </h3>

        <table>
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Produit</th>
                    <th>Quantité</th>
                    <th>Prix</th>
                    <th>Total</th>
                </tr>
            </thead>

            <tbody>
                {% for item in order.orderItems %}
                    <tr>
                        <td>
                            <img src="{{ asset(item.product.imageUrl) }}" width="60">
                        </td>
                        <td>{{ item.product.name }}</td>
                        <td>{{ item.quantity }}</td>
                        <td>{{ item.product.price }} €</td>
                        <td>
                            <strong>
                                {{ item.quantity * item.product.price }} €
                            </strong>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        <div class="total-box">
            Total: {{ order.totalPrice }} €
        </div>

    </div>

</div>

{% endblock %}