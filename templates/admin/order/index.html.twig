{% extends 'base_admin.html.twig' %}

{% block title %}Gestion des commandes{% endblock %}

{% block body %}

<h1 class="page-title">
    📦 Gestion des commandes
</h1>

{% if orders|length > 0 %}

<div class="table-container">

    <table>

        <thead>
            <tr>
                <th>ID</th>
                <th>User</th>
                <th>Date</th>
                <th>Total</th>
                <th>Méthode de paiement</th>
                <th>Status</th>
                <th>Détails</th>
            </tr>
        </thead>

        <tbody>

        {% for order in orders %}
            <tr>

                <td>#{{ order.id }}</td>

                <td>{{ order.user.email }}</td>

                <td>{{ order.createdAt|date('d/m/Y H:i') }}</td>

                <td><strong>{{ order.totalPrice }} €</strong></td>

                <td>
                    {% if order.paymentMethod == 'stripe' %}
                        💳 Carte bancaire
                    {% elseif order.paymentMethod == 'cod' %}
                        💵 À la livraison
                    {% else %}
                        ❓ Inconnu
                    {% endif %}

                    <br>

                    <small>
                        Paiement:
                        {% if order.paymentStatus == 'paid' %}
                            ✅ Payé
                        {% elseif order.paymentStatus == 'pending' %}
                            ⏳ En attente
                        {% else %}
                            ❌ Échoué
                        {% endif %}
                    </small>
                </td>

                <td>

                    <form method="post" action="{{ path('admin_order_update_status', {id: order.id}) }}">

                        <select name="status"
                                onchange="this.form.submit()"
                                class="status-select
                                    {% if order.status == 'En attente' %}status-attente{% endif %}
                                    {% if order.status == 'Validé' %}status-valide{% endif %}
                                    {% if order.status == 'Expédié' %}status-expedie{% endif %}
                                    {% if order.status == 'Annulé' %}status-annule{% endif %}
                                ">

                            <option value="En attente" {% if order.status == 'En attente' %}selected{% endif %}>En attente</option>
                            <option value="Validé" {% if order.status == 'Validé' %}selected{% endif %}>Validé</option>
                            <option value="Expédié" {% if order.status == 'Expédié' %}selected{% endif %}>Expédié</option>
                            <option value="Annulé" {% if order.status == 'Annulé' %}selected{% endif %}>Annulé</option>

                        </select>

                    </form>

                    {% if order.status == 'Annulé' %}
                        {% if order.cancelledBy == 'client' %}
                            <span class="badge bg-danger">Annulé (client)</span>
                        {% else %}
                            <span class="badge bg-dark">Annulé (admin)</span>
                        {% endif %}
                    {% endif %}

                </td>

                <td>
                    <a href="{{ path('admin_order_show', {id: order.id}) }}" class="btn-link">
                        Voir
                    </a>
                </td>

            </tr>
        {% endfor %}

        </tbody>

    </table>

</div>

{% else %}
    <p>Aucune commande trouvée.</p>
{% endif %}

<div class="d-flex justify-content-center mt-4">
    {{ knp_pagination_render(orders, '@KnpPaginator/Pagination/bootstrap_v5_pagination.html.twig') }}
</div>

{% endblock %}